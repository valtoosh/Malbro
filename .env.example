# Backend (apps/backend/.env)
DATABASE_URL=
MAGIC_LINK_SECRET=replace_me_with_32_byte_hex
RESEND_API_KEY=
RESEND_FROM=
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
PORT=3001

# Twitter (set both for real OAuth, leave blank for stub mode)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# R2 (leave blank to use local filesystem ./uploads)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Squads (leave blank for stub mode)
SQUADS_PROPOSER_SK=
SQUADS_MULTISIG_PUBKEY=

# Frontend (apps/frontend/.env.local)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
